# Copy this file to .env and fill values
# cp .env.example .env

PORT=5000
NODE_ENV=production
HOST=0.0.0.0
TRUST_PROXY=true

# Gmail SMTP Settings
# Use Gmail App Password not your real password
# Get App Password: myaccount.google.com > Security > App Passwords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=youremail@gmail.com
SMTP_PASS=xxxx xxxx xxxx xxxx

# Where to receive form submissions
RECEIVER_EMAIL=owneremail@gmail.com

# Company name shown in emails
COMPANY_NAME=LIFEE Premium Water

# Development
FRONTEND_URL=http://localhost:5174

# Production - add your domain here
FRONTEND_URL_PROD=https://yourdomain.com

# Optional email reliability tuning
EMAIL_MAX_RETRIES=2
EMAIL_ACK_RETRIES=1
EMAIL_RETRY_DELAY_MS=1200
EMAIL_QUEUE_MAX=200
